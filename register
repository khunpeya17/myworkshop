<!DOCTYPE html>
<html lang="th">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>ฟอร์มลงทะเบียนผู้ป่วย</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" crossorigin="anonymous" />
  </head>
  <body>
    <div class="container py-5">
      <div class="row justify-content-center">
        <div class="col-12 col-lg-8">
          <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
              <h2 class="mb-0">ลงทะเบียนผู้ป่วย</h2>
              <p class="mb-0">กรุณากรอกข้อมูลให้ครบถ้วนเพื่อบันทึกการนัดหมาย</p>
            </div>
            <div class="card-body">
              <form>
                <div class="row g-3">
                  <div class="col-md-6">
                    <label for="firstName" class="form-label">ชื่อ</label>
                    <input type="text" class="form-control" id="firstName" placeholder="ชื่อจริง" required />
                  </div>
                  <div class="col-md-6">
                    <label for="lastName" class="form-label">นามสกุล</label>
                    <input type="text" class="form-control" id="lastName" placeholder="นามสกุล" required />
                  </div>

                  <div class="col-md-6">
                    <label for="birthDate" class="form-label">วันเกิด</label>
                    <input type="date" class="form-control" id="birthDate" required />
                  </div>
                  <div class="col-md-6">
                    <label class="form-label d-block">เพศ</label>
                    <div class="form-check form-check-inline">
                      <input class="form-check-input" type="radio" name="gender" id="genderMale" value="male" checked />
                      <label class="form-check-label" for="genderMale">ชาย</label>
                    </div>
                    <div class="form-check form-check-inline">
                      <input class="form-check-input" type="radio" name="gender" id="genderFemale" value="female" />
                      <label class="form-check-label" for="genderFemale">หญิง</label>
                    </div>
                    <div class="form-check form-check-inline">
                      <input class="form-check-input" type="radio" name="gender" id="genderOther" value="other" />
                      <label class="form-check-label" for="genderOther">อื่น ๆ</label>
                    </div>
                  </div>

                  <div class="col-md-6">
                    <label for="phone" class="form-label">เบอร์โทรศัพท์</label>
                    <input type="tel" class="form-control" id="phone" placeholder="081-234-5678" required />
                  </div>
                  <div class="col-md-6">
                    <label for="email" class="form-label">อีเมล</label>
                    <input type="email" class="form-control" id="email" placeholder="example@mail.com" />
                  </div>

                  <div class="col-12">
                    <label for="address" class="form-label">ที่อยู่</label>
                    <textarea class="form-control" id="address" rows="3" placeholder="บ้านเลขที่ แขวง/ตำบล ..." required></textarea>
                  </div>

                  <div class="col-md-4">
                    <label for="bloodType" class="form-label">กรุ๊ปเลือด</label>
                    <select class="form-select" id="bloodType">
                      <option selected>เลือกกรุ๊ปเลือด</option>
                      <option value="A">A</option>
                      <option value="B">B</option>
                      <option value="AB">AB</option>
                      <option value="O">O</option>
                    </select>
                  </div>
                  <div class="col-md-4">
                    <label for="allergies" class="form-label">ประวัติภูมิแพ้</label>
                    <input type="text" class="form-control" id="allergies" placeholder="เช่น ผื่น ลมพิษ" />
                  </div>
                  <div class="col-md-4">
                    <label for="chronic" class="form-label">โรคประจำตัว</label>
                    <input type="text" class="form-control" id="chronic" placeholder="เช่น เบาหวาน ความดัน" />
                  </div>

                  <div class="col-12">
                    <label for="symptoms" class="form-label">อาการที่มาพบแพทย์</label>
                    <textarea class="form-control" id="symptoms" rows="3" placeholder="อาการหรือปัญหาทางสุขภาพ" required></textarea>
                  </div>

                  <div class="col-12">
                    <div class="form-check">
                      <input class="form-check-input" type="checkbox" id="confirm" required />
                      <label class="form-check-label" for="confirm">ยืนยันว่าข้อมูลทั้งหมดถูกต้อง</label>
                    </div>
                  </div>

                  <div class="col-12 d-flex justify-content-end gap-2">
                    <button type="reset" class="btn btn-outline-secondary">รีเซ็ต</button>
                    <button type="submit" class="btn btn-primary">ลงทะเบียน</button>
                  </div>
                </div>
              </form>
            </div>
          </div>
        </div>
      </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
  </body>
</html>